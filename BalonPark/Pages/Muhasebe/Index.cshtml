@page "/muhasebe"
@model BalonPark.Pages.Muhasebe.IndexModel
@{
    Layout = "_MuhasebeLayout";
    ViewData["Title"] = "Özet";
}

<div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-3">
        <svg class="w-8 h-8 text-gray-900 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Muhasebe özeti
    </h1>
    <p class="text-gray-600 mt-2">Seçili şirket için cari ve fatura özetine buradan ulaşabilirsiniz.</p>
</div>

<div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-8">
    <div class="bg-white overflow-hidden rounded-lg shadow-md">
        <div class="p-6">
            <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">Aktif cari</p>
            <p class="mt-2 text-3xl font-bold text-gray-900">@Model.CounterpartyCount</p>
            <a href="/muhasebe/cariler" class="mt-4 inline-flex items-center text-sm font-semibold text-gray-900 hover:text-gray-700">
                Carilere git
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
        </div>
    </div>
    <div class="bg-white overflow-hidden rounded-lg shadow-md">
        <div class="p-6">
            <p class="text-sm font-medium text-gray-500 uppercase tracking-wide">Fatura kaydı</p>
            <p class="mt-2 text-3xl font-bold text-gray-900">@Model.InvoiceCount</p>
            <a href="/muhasebe/faturalar" class="mt-4 inline-flex items-center text-sm font-semibold text-gray-900 hover:text-gray-700">
                Faturalara git
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
        </div>
    </div>
</div>

<div class="bg-white rounded-lg shadow-md overflow-hidden mb-2">
    <div class="px-6 py-4 border-b border-gray-200">
        <h2 class="text-lg font-bold text-gray-800">Son hareketler</h2>
        <p class="text-sm text-gray-500 mt-1">Şirkete ait son kayıtlar</p>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tarih</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cari</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tür</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kaynak</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Tutar</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var m in Model.RecentMovements)
                {
                    var alacak = m.IsCredit;
                    var rowClass = alacak
                        ? "bg-green-50/90 hover:bg-green-100 border-l-4 border-l-green-600"
                        : "bg-red-50/90 hover:bg-red-100 border-l-4 border-l-red-600";
                    var turClass = alacak ? "text-green-800 font-semibold" : "text-red-800 font-semibold";
                    var tutarClass = alacak ? "text-green-900" : "text-red-900";
                    <tr class="@rowClass transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@m.MovementDate.ToString("dd.MM.yyyy")</td>
                        <td class="px-6 py-4 text-sm text-gray-900">@(m.CounterpartyName ?? "—")</td>
                        <td class="px-6 py-4 text-sm @turClass">@(alacak ? "Alacak" : "Borç")</td>
                        <td class="px-6 py-4 text-sm text-gray-600">@MuhasebeUiTurkish.HareketReferansi(m.ReferenceType)@(m.ReferenceId.HasValue ? $" · No {m.ReferenceId}" : "")</td>
                        <td class="px-6 py-4 text-sm font-semibold @tutarClass text-right tabular-nums">@m.Amount.ToString("N2") @m.Currency</td>
                    </tr>
                }
                @if (Model.RecentMovements.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-gray-500 text-sm">Henüz hareket yok.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
