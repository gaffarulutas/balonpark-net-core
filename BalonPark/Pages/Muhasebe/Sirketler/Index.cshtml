@page "/muhasebe/sirketler"
@model BalonPark.Pages.Muhasebe.Sirketler.IndexModel
@{
    Layout = "_MuhasebeLayout";
    ViewData["Title"] = "Şirketler";
}

<div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-3">
                <svg class="w-8 h-8 text-gray-900 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                </svg>
                Muhasebe şirketleri
            </h1>
            <p class="text-gray-600 mt-2">Şirket kayıtlarını görüntüleyin, düzenleyin veya yeni şirket ekleyin.</p>
        </div>
        <div>
            <button type="button" id="btnSirketCreateOpen" class="inline-flex items-center px-4 py-2 bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-lg transition-colors duration-200 shadow-md">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Yeni şirket
            </button>
        </div>
    </div>
</div>

<div class="bg-white rounded-lg shadow-md overflow-hidden">
    @if (Model.Companies.Count == 0)
    {
        <div class="text-center py-12 px-4">
            <svg class="mx-auto w-16 h-16 text-gray-400 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
            <h3 class="text-xl font-semibold text-gray-700 mb-2">Henüz şirket yok</h3>
            <p class="text-gray-500 mb-6">İlk muhasebe şirketini oluşturmak için butona tıklayın.</p>
            <button type="button" id="btnSirketCreateOpenEmpty" class="inline-flex items-center px-6 py-3 bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-lg transition-colors duration-200 shadow-md">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Şirket ekle
            </button>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Unvan</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">VKN</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Para</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Durum</th>
                        <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">İşlem</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var c in Model.Companies)
                    {
                        <tr class="hover:bg-gray-50 transition-colors duration-150">
                            <td class="px-6 py-4 text-sm font-semibold text-gray-900">@c.LegalName</td>
                            <td class="px-6 py-4 text-sm text-gray-600">@(c.TaxId ?? "—")</td>
                            <td class="px-6 py-4 text-sm text-gray-600">@c.DefaultCurrency</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (c.IsActive)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">Aktif</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">Pasif</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <a href="/muhasebe/sirketler?duzenle=@c.Id" class="inline-flex items-center px-3 py-1.5 bg-gray-900 hover:bg-gray-800 text-white rounded-md transition-colors duration-200">
                                    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                                    Düzenle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Yeni şirket -->
<div id="sirketCreateModal" class="fixed inset-0 z-[70] hidden" role="dialog" aria-modal="true" aria-labelledby="sirketCreateTitle" aria-hidden="true">
    <button type="button" class="sirket-create-backdrop absolute inset-0 bg-gray-900/60 backdrop-blur-[1px]" aria-label="Kapat"></button>
    <div class="relative flex min-h-full items-center justify-center p-4 pointer-events-none">
        <div class="pointer-events-auto bg-white rounded-xl shadow-2xl max-w-3xl w-full max-h-[calc(100vh-2rem)] overflow-y-auto border border-gray-200">
            <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-gray-200 sticky top-0 bg-white rounded-t-xl">
                <div>
                    <h3 id="sirketCreateTitle" class="text-lg font-bold text-gray-900">Yeni muhasebe şirketi</h3>
                    <p class="text-sm text-gray-600 mt-1">Yasal unvan ve iletişim bilgilerini girin.</p>
                </div>
                <button type="button" id="sirketCreateClose" class="p-2 rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-100 transition-colors shrink-0" aria-label="Kapat">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <form method="post" asp-page-handler="CreateCompany" id="formSirketCreate" class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-x-5 gap-y-4">
                <div asp-validation-summary="ModelOnly" class="sm:col-span-2 rounded-md bg-red-50 border border-red-200 text-red-800 text-sm px-4 py-3"></div>
                <div class="sm:col-span-2 min-w-0">
                    <label asp-for="CreateCompanyInput.LegalName" class="block text-sm font-medium text-gray-700 mb-2">Yasal unvan <span class="text-red-500">*</span></label>
                    <input asp-for="CreateCompanyInput.LegalName" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                    <span asp-validation-for="CreateCompanyInput.LegalName" class="text-red-600 text-sm mt-1 block"></span>
                </div>
                <div class="min-w-0">
                    <label asp-for="CreateCompanyInput.TaxId" class="block text-sm font-medium text-gray-700 mb-2">VKN / TCKN</label>
                    <input asp-for="CreateCompanyInput.TaxId" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="min-w-0">
                    <label asp-for="CreateCompanyInput.TaxOffice" class="block text-sm font-medium text-gray-700 mb-2">Vergi dairesi</label>
                    <input asp-for="CreateCompanyInput.TaxOffice" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="sm:col-span-2 min-w-0">
                    <partial name="_MuhasebeIsoCurrencySelect" model='@(new IsoCurrencySelectViewModel { FieldName = "CreateCompanyInput.DefaultCurrency", Selected = Model.CreateCompanyInput.DefaultCurrency, Label = "Varsayılan para birimi", ControlId = "sirketCreateCurrency", ShowHint = false })' />
                </div>
                <div class="sm:col-span-2 min-w-0">
                    <label asp-for="CreateCompanyInput.Address" class="block text-sm font-medium text-gray-700 mb-2">Adres</label>
                    <textarea asp-for="CreateCompanyInput.Address" rows="3" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200"></textarea>
                </div>
                <div class="min-w-0">
                    <label asp-for="CreateCompanyInput.Phone" class="block text-sm font-medium text-gray-700 mb-2">Telefon</label>
                    <input asp-for="CreateCompanyInput.Phone" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="min-w-0">
                    <label asp-for="CreateCompanyInput.Email" class="block text-sm font-medium text-gray-700 mb-2">E-posta</label>
                    <input asp-for="CreateCompanyInput.Email" type="email" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="sm:col-span-2 flex items-center">
                    <input asp-for="CreateCompanyInput.IsActive" type="checkbox" class="w-4 h-4 text-gray-900 border-gray-300 rounded focus:ring-gray-800" />
                    <label asp-for="CreateCompanyInput.IsActive" class="ml-2 block text-sm text-gray-900">Aktif</label>
                </div>
                <div class="sm:col-span-2 flex flex-wrap items-center gap-3 pt-3 mt-1 border-t border-gray-200">
                    <button type="submit" class="inline-flex items-center px-6 py-3 bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-lg transition-colors duration-200 shadow-md" data-loading-text="Kaydediliyor...">Kaydet</button>
                    <button type="button" id="sirketCreateCancel" class="inline-flex items-center px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium rounded-lg transition-colors duration-200">İptal</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Şirket düzenle -->
<div id="sirketEditModal" class="fixed inset-0 z-[70] hidden" role="dialog" aria-modal="true" aria-labelledby="sirketEditTitle" aria-hidden="true">
    <button type="button" class="sirket-edit-backdrop absolute inset-0 bg-gray-900/60 backdrop-blur-[1px]" aria-label="Kapat"></button>
    <div class="relative flex min-h-full items-center justify-center p-4 pointer-events-none">
        <div class="pointer-events-auto bg-white rounded-xl shadow-2xl max-w-3xl w-full max-h-[calc(100vh-2rem)] overflow-y-auto border border-gray-200">
            <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-gray-200 sticky top-0 bg-white rounded-t-xl">
                <div>
                    <h3 id="sirketEditTitle" class="text-lg font-bold text-gray-900">Şirket düzenle</h3>
                    <p class="text-sm text-gray-600 mt-1">Kayıt bilgilerini güncelleyin.</p>
                </div>
                <button type="button" id="sirketEditClose" class="p-2 rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-100 transition-colors shrink-0" aria-label="Kapat">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <form method="post" asp-page-handler="EditCompany" id="formSirketEdit" class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-x-5 gap-y-4">
                <div class="sm:col-span-2"><input type="hidden" asp-for="EditCompanyId" /></div>
                <div asp-validation-summary="ModelOnly" class="sm:col-span-2 rounded-md bg-red-50 border border-red-200 text-red-800 text-sm px-4 py-3"></div>
                <div class="sm:col-span-2 min-w-0">
                    <label asp-for="EditCompanyInput.LegalName" class="block text-sm font-medium text-gray-700 mb-2">Yasal unvan <span class="text-red-500">*</span></label>
                    <input asp-for="EditCompanyInput.LegalName" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                    <span asp-validation-for="EditCompanyInput.LegalName" class="text-red-600 text-sm mt-1 block"></span>
                </div>
                <div class="min-w-0">
                    <label asp-for="EditCompanyInput.TaxId" class="block text-sm font-medium text-gray-700 mb-2">VKN / TCKN</label>
                    <input asp-for="EditCompanyInput.TaxId" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="min-w-0">
                    <label asp-for="EditCompanyInput.TaxOffice" class="block text-sm font-medium text-gray-700 mb-2">Vergi dairesi</label>
                    <input asp-for="EditCompanyInput.TaxOffice" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="sm:col-span-2 min-w-0">
                    <partial name="_MuhasebeIsoCurrencySelect" model='@(new IsoCurrencySelectViewModel { FieldName = "EditCompanyInput.DefaultCurrency", Selected = Model.EditCompanyInput.DefaultCurrency, Label = "Varsayılan para birimi", ControlId = "sirketEditCurrency", ShowHint = false })' />
                </div>
                <div class="sm:col-span-2 min-w-0">
                    <label asp-for="EditCompanyInput.Address" class="block text-sm font-medium text-gray-700 mb-2">Adres</label>
                    <textarea asp-for="EditCompanyInput.Address" rows="3" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200"></textarea>
                </div>
                <div class="min-w-0">
                    <label asp-for="EditCompanyInput.Phone" class="block text-sm font-medium text-gray-700 mb-2">Telefon</label>
                    <input asp-for="EditCompanyInput.Phone" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="min-w-0">
                    <label asp-for="EditCompanyInput.Email" class="block text-sm font-medium text-gray-700 mb-2">E-posta</label>
                    <input asp-for="EditCompanyInput.Email" type="email" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="sm:col-span-2 flex items-center">
                    <input asp-for="EditCompanyInput.IsActive" type="checkbox" class="w-4 h-4 text-gray-900 border-gray-300 rounded focus:ring-gray-800" />
                    <label asp-for="EditCompanyInput.IsActive" class="ml-2 block text-sm text-gray-900">Aktif</label>
                </div>
                <div class="sm:col-span-2 flex flex-wrap items-center gap-3 pt-3 mt-1 border-t border-gray-200">
                    <button type="submit" class="inline-flex items-center px-6 py-3 bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-lg transition-colors duration-200 shadow-md" data-loading-text="Kaydediliyor...">Kaydet</button>
                    <button type="button" id="sirketEditCancel" class="inline-flex items-center px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium rounded-lg transition-colors duration-200">İptal</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var createModal = document.getElementById('sirketCreateModal');
            var editModal = document.getElementById('sirketEditModal');
            function bodyScroll(lock) {
                document.body.classList.toggle('overflow-hidden', lock);
            }
            function openCreate() {
                if (editModal) { editModal.classList.add('hidden'); editModal.setAttribute('aria-hidden', 'true'); }
                if (!createModal) return;
                createModal.classList.remove('hidden');
                createModal.setAttribute('aria-hidden', 'false');
                bodyScroll(true);
                var el = createModal.querySelector('#formSirketCreate input:not([type=hidden]):not([type=checkbox]), #formSirketCreate textarea');
                if (el) el.focus();
            }
            function closeCreate() {
                if (!createModal) return;
                createModal.classList.add('hidden');
                createModal.setAttribute('aria-hidden', 'true');
                bodyScroll(!!(editModal && !editModal.classList.contains('hidden')));
            }
            function openEdit() {
                if (createModal) { createModal.classList.add('hidden'); createModal.setAttribute('aria-hidden', 'true'); }
                if (!editModal) return;
                editModal.classList.remove('hidden');
                editModal.setAttribute('aria-hidden', 'false');
                bodyScroll(true);
                var el = editModal.querySelector('#formSirketEdit input:not([type=hidden]):not([type=checkbox]), #formSirketEdit textarea');
                if (el) el.focus();
            }
            function closeEdit() {
                if (!editModal) return;
                editModal.classList.add('hidden');
                editModal.setAttribute('aria-hidden', 'true');
                bodyScroll(!!(createModal && !createModal.classList.contains('hidden')));
            }
            function closeAll() {
                closeCreate();
                closeEdit();
                bodyScroll(false);
            }
            var btnC1 = document.getElementById('btnSirketCreateOpen');
            var btnC2 = document.getElementById('btnSirketCreateOpenEmpty');
            if (btnC1) btnC1.addEventListener('click', openCreate);
            if (btnC2) btnC2.addEventListener('click', openCreate);
            document.getElementById('sirketCreateClose')?.addEventListener('click', closeCreate);
            document.getElementById('sirketCreateCancel')?.addEventListener('click', closeCreate);
            document.querySelector('.sirket-create-backdrop')?.addEventListener('click', closeCreate);
            document.getElementById('sirketEditClose')?.addEventListener('click', closeEdit);
            document.getElementById('sirketEditCancel')?.addEventListener('click', closeEdit);
            document.querySelector('.sirket-edit-backdrop')?.addEventListener('click', closeEdit);
            document.addEventListener('keydown', function (e) {
                if (e.key !== 'Escape') return;
                if (editModal && !editModal.classList.contains('hidden')) { closeEdit(); return; }
                if (createModal && !createModal.classList.contains('hidden')) closeCreate();
            });
            @if (Model.OpenEditModal)
            {
                <text>openEdit();</text>
            }
            else if (Model.OpenCreateModal)
            {
                <text>openCreate();</text>
            }
        })();
    </script>
}
