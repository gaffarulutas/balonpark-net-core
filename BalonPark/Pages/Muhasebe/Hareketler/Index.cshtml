@page "/muhasebe/hareketler"
@model BalonPark.Pages.Muhasebe.Hareketler.IndexModel
@{
    Layout = "_MuhasebeLayout";
    ViewData["Title"] = "Hareketler";
}

<div class="bg-white rounded-lg shadow-md p-6 mb-6">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-800 flex items-center gap-3">
                <svg class="w-8 h-8 text-gray-900 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z" /></svg>
                Cari hareketler
            </h1>
            <p class="text-gray-600 mt-2">Tüm hareketleri filtreleyin; manuel borç/alacak kaydı eklemek için butonu kullanın.</p>
        </div>
        <div>
            <button type="button" id="btnManuelHareketOpen" class="inline-flex items-center px-4 py-2 bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-lg transition-colors duration-200 shadow-md">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>
                Manuel hareket
            </button>
        </div>
    </div>
</div>

<div class="bg-white rounded-lg shadow-md p-6 mb-8">
    <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wider mb-4">Filtre</h2>
    <form method="get" class="flex flex-wrap items-end gap-4">
        <div class="min-w-[12rem]">
            <label class="block text-sm font-medium text-gray-700 mb-2">Cari</label>
            <select name="CariId" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200">
                <option value="">Tümü</option>
                @foreach (var c in Model.Counterparties)
                {
                    if (Model.CariId == c.Id)
                    {
                        <option value="@c.Id" selected="selected">@c.Name</option>
                    }
                    else
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                }
            </select>
        </div>
        <button type="submit" class="inline-flex items-center px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-900 font-medium rounded-lg transition-colors duration-200">Filtrele</button>
    </form>
</div>

<div class="bg-white rounded-lg shadow-md overflow-hidden mb-10">
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tarih</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Cari</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Tür</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Kaynak</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Açıklama</th>
                    <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Tutar</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var m in Model.Movements)
                {
                    var alacak = m.IsCredit;
                    var rowClass = alacak
                        ? "bg-green-50/90 hover:bg-green-100 border-l-4 border-l-green-600"
                        : "bg-red-50/90 hover:bg-red-100 border-l-4 border-l-red-600";
                    var turClass = alacak ? "text-green-800 font-semibold" : "text-red-800 font-semibold";
                    var tutarClass = alacak ? "text-green-900" : "text-red-900";
                    <tr class="@rowClass transition-colors duration-150">
                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@m.MovementDate.ToString("dd.MM.yyyy")</td>
                        <td class="px-6 py-4 text-sm text-gray-900">@(m.CounterpartyName ?? "—")</td>
                        <td class="px-6 py-4 text-sm @turClass">@(alacak ? "Alacak" : "Borç")</td>
                        <td class="px-6 py-4 text-sm text-gray-600">@MuhasebeUiTurkish.HareketReferansi(m.ReferenceType)@(m.ReferenceId.HasValue ? $" · No {m.ReferenceId}" : "")</td>
                        <td class="px-6 py-4 text-sm text-gray-700">@(m.Description ?? "—")</td>
                        <td class="px-6 py-4 text-sm font-semibold @tutarClass text-right tabular-nums">@m.Amount.ToString("N2") @m.Currency</td>
                    </tr>
                }
                @if (Model.Movements.Count == 0)
                {
                    <tr><td colspan="6" class="px-6 py-10 text-center text-gray-500 text-sm">Kayıt yok.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div id="manuelHareketModal" class="fixed inset-0 z-[70] hidden" role="dialog" aria-modal="true" aria-labelledby="manuelHareketTitle" aria-hidden="true">
    <button type="button" id="manuelHareketBackdrop" class="absolute inset-0 bg-gray-900/60 backdrop-blur-[1px]" aria-label="Kapat"></button>
    <div class="relative flex min-h-full items-center justify-center p-4 pointer-events-none">
        <div class="pointer-events-auto bg-white rounded-xl shadow-2xl max-w-2xl w-full max-h-[calc(100vh-2rem)] overflow-y-auto border border-gray-200">
            <div class="flex items-start justify-between gap-4 px-6 py-4 border-b border-gray-200 sticky top-0 bg-white rounded-t-xl">
                <div>
                    <h3 id="manuelHareketTitle" class="text-lg font-bold text-gray-900">Manuel hareket</h3>
                    <p class="text-sm text-gray-600 mt-1">Borç veya alacak tarafına manuel kayıt ekleyin.</p>
                </div>
                <button type="button" id="manuelHareketClose" class="p-2 rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-100 transition-colors shrink-0" aria-label="Kapat">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                </button>
            </div>
            <form method="post" asp-page-handler="Manuel" id="formManuelHareket" class="px-6 py-5 grid grid-cols-1 sm:grid-cols-2 gap-x-5 gap-y-4">
                @if (Model.CariId.HasValue)
                {
                    <div class="sm:col-span-2"><input type="hidden" name="CariId" value="@Model.CariId.Value" /></div>
                }
                <div asp-validation-summary="All" class="sm:col-span-2 rounded-md bg-red-50 border border-red-200 text-red-800 text-sm px-4 py-3"></div>
                <div class="sm:col-span-2 min-w-0">
                    <label asp-for="ManualInput.CounterpartyId" class="block text-sm font-medium text-gray-700 mb-2">Cari</label>
                    <select asp-for="ManualInput.CounterpartyId" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200">
                        @foreach (var c in Model.Counterparties.Where(x => x.IsActive))
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
                <div class="min-w-0">
                    <label asp-for="ManualInput.MovementDate" class="block text-sm font-medium text-gray-700 mb-2">Tarih</label>
                    <input asp-for="ManualInput.MovementDate" type="date" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="min-w-0">
                    <label asp-for="ManualInput.Side" class="block text-sm font-medium text-gray-700 mb-2">Taraf</label>
                    <select asp-for="ManualInput.Side" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200">
                        <option value="credit">Alacak</option>
                        <option value="debit">Borç</option>
                    </select>
                </div>
                <div class="min-w-0">
                    <label asp-for="ManualInput.Amount" class="block text-sm font-medium text-gray-700 mb-2">Tutar</label>
                    <input asp-for="ManualInput.Amount" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <partial name="_MuhasebeIsoCurrencySelect" model='@(new IsoCurrencySelectViewModel { FieldName = "ManualInput.Currency", Selected = Model.ManualInput.Currency, Label = "Para birimi", ControlId = "hareketManuelCurrency" })' />
                <div class="sm:col-span-2 min-w-0">
                    <label asp-for="ManualInput.Description" class="block text-sm font-medium text-gray-700 mb-2">Açıklama</label>
                    <input asp-for="ManualInput.Description" class="w-full min-w-0 px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-800 focus:border-transparent transition-all duration-200" />
                </div>
                <div class="sm:col-span-2 flex flex-wrap items-center gap-3 pt-3 mt-1 border-t border-gray-200">
                    <button type="submit" class="inline-flex items-center px-6 py-3 bg-gray-900 hover:bg-gray-800 text-white font-medium rounded-lg transition-colors duration-200 shadow-md" data-loading-text="Kaydediliyor...">Kaydet</button>
                    <button type="button" id="manuelHareketCancel" class="inline-flex items-center px-6 py-3 bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium rounded-lg transition-colors duration-200">İptal</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            var modal = document.getElementById('manuelHareketModal');
            if (!modal) return;
            function openModal() {
                modal.classList.remove('hidden');
                modal.setAttribute('aria-hidden', 'false');
                document.body.classList.add('overflow-hidden');
                var first = modal.querySelector('#formManuelHareket select, #formManuelHareket input:not([type=hidden])');
                if (first) first.focus();
            }
            function closeModal() {
                modal.classList.add('hidden');
                modal.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('overflow-hidden');
            }
            document.getElementById('btnManuelHareketOpen')?.addEventListener('click', openModal);
            document.getElementById('manuelHareketClose')?.addEventListener('click', closeModal);
            document.getElementById('manuelHareketCancel')?.addEventListener('click', closeModal);
            document.getElementById('manuelHareketBackdrop')?.addEventListener('click', closeModal);
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
            });
            @if (Model.OpenManuelModal)
            {
                <text>openModal();</text>
            }
        })();
    </script>
}
